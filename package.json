{
  "name": "mechanical-association-website",
  "version": "2.0.0",
  "description": "Official website for the Mechanical Engineering Association — College of Engineering Trivandrum with Vercel-compatible serverless APIs and PostgreSQL support.",
  "main": "api/index.js",
  "scripts": {
    "dev": "node server.js",
    "start": "node server.js",
    "vercel:dev": "npx vercel dev",
    "seed": "node -e \"require('./db').seedDatabase().then(() => console.log('Database initialized')).catch(err => { console.error(err); process.exit(1); })\""
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "cookie": "^0.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.1",
    "mysql2": "^3.12.0"
  },
  "keywords": [
    "mechanical-engineering",
    "college-website",
    "association",
    "cet",
    "trivandrum",
    "vercel",
    "postgresql"
  ],
  "license": "ISC"
}
