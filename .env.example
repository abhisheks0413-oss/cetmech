# .env.example   (keep this in the repo – it’s only a template)

# MySQL connection string from your hosting provider
DATABASE_URL=mysql://username:password@host:3306/database_name?ssl-mode=require

# JWT secret for admin authentication
JWT_SECRET=your_jwt_secret_here

# Session secret (used by cookie‑parser / JWT verification)
SESSION_SECRET=your_session_secret_here

# Admin panel credentials (you can keep “admin” for local testing)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin_password_here