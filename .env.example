# Environment Configuration
# Copy this file to .env and fill in your values before running the server.
# Never commit your real .env file to version control.

# Port the server will listen on
PORT=3000

# Secret key for signing session cookies — use a long random string in production
SESSION_SECRET=change_this_to_a_long_random_secret_key

# Admin panel credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
