{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/server.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/academics", "dest": "/academics.html" },
    { "src": "/admin", "dest": "/admin.html" },
    { "src": "/events", "dest": "/events.html" },
    { "src": "/help", "dest": "/help.html" },
    { "src": "/notices", "dest": "/notices.html" }
  ]
}