{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/academics", "destination": "/academics.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/events", "destination": "/events.html" },
    { "source": "/help", "destination": "/help.html" },
    { "source": "/notices", "destination": "/notices.html" }
  ]
}
